#!/usr/bin/env bash
# eos — orchestration CLI launcher
set -euo pipefail
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
dir="$(cd -P "$(dirname "$src")" && pwd)"
repo_root="$(cd "$dir/../.." && pwd)"
exec node --no-warnings --experimental-strip-types "$repo_root/manager/cli.ts" "$@"
