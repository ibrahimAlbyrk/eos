; @anthropic-ai/claude-agent-sdk declares a peer of zod@^4, but Eos is on zod@3
; across contracts/core/manager. This is safe: the SDK's tool() accepts a zod-3
; raw shape (AnyZodRawShape = ZodRawShape(v3) | ZodRawShape(v4)) and zod 3.25
; ships the `zod/v4` subpath the SDK imports. Accept the peer mismatch so a plain
; `npm install` (eos build's deps step) resolves instead of erroring (ERESOLVE).
legacy-peer-deps=true
