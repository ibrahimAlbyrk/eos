{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["server.ts", "envelope.ts", "admission.ts", "RoomRegistry.ts", "errors.ts", "apns.ts", "config.ts", "__tests__/*.ts"]
}
